rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidSubmission(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 50;
    }

    match /submissions/{submissionId} {
      allow create: if true; // Allow public submissions for this demo
      allow read: if isAuthenticated();
    }

    match /winners/{winnerId} {
      allow read: if true; // Allow public to see the winner
      allow write: if isAuthenticated(); // Only authenticated users (admin) can update the winner
    }
  }
}
